#!/usr/bin/env bash
# tmux-auto-name: rename tmux windows deterministically.
#
# Format:
#   AI coder running:    "<tool>:<repo>:<slug>"   slug LLM-derived once, cached per pane.
#   Plain shell in repo: "<repo>"  or  "<repo>:<fg_cmd>"  if a recognized cmd is foreground.
#   Otherwise: leave alone.
#
# The only LLM call is the slug for AI panes, and it's cached forever per
# (pane_id, tool, repo). Killing+reopening a window regenerates. `--once`
# bypasses the cache (so prefix+N means "regenerate this").
set -uo pipefail

MODEL="${TAN_MODEL:-qwen2.5:1.5b}"
INTERVAL="${TAN_INTERVAL:-30}"
LINES="${TAN_LINES:-80}"
HOST="${TAN_OLLAMA_HOST:-http://localhost:11434}"
RENAME_ALL="${TAN_RENAME_ALL:-0}"
MAXLEN="${TAN_MAXLEN:-40}"

TOOL_MAX=12
REPO_MAX=14
SLUG_MAX=12

CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/tmux-auto-name"
CACHE_FILE="$CACHE_DIR/slugs.tsv"

DEFAULT_NAME_RE='^(zsh|bash|sh|fish|[0-9]+)$'
AI_TOOLS_RE='(claude|codex|opencode|gemini|goose|aider|droid|crush|cursor|cody)'
VERSION_CMD_RE='^[0-9]+\.[0-9]+(\.[0-9]+)?$'
# Order: longer alternatives first so substring match doesn't shadow them (nvim before vim, nodemon before node).
FG_CMDS_RE='(nvim|vim|nano|emacs|less|man|psql|nodemon|node|python|ruby|cargo|npm|pnpm|yarn|make|docker|k9s|htop|btop|lazygit|tig|gh|ssh|vi)'
AI_TOOL_LABELS=(claude codex opencode gemini goose aider droid crush cursor cody)

log() { printf '[tan %s] %s\n' "$(date +%H:%M:%S)" "$*" >&2; }

# --- pure helpers ---

sanitize_label() {
  local maxlen="${1:-24}"
  tr '[:upper:]' '[:lower:]' \
    | tr -d '"`'"'" \
    | tr -c 'a-z0-9 \n' ' ' \
    | awk '{
        n = (NF < 3) ? NF : 3
        if (n == 0) { print ""; next }
        out = $1
        for (i = 2; i <= n; i++) out = out "-" $i
        print out
      }' \
    | cut -c1-"$maxlen"
}

repo_for_path() {
  local path="$1" repo
  [[ -z "$path" || ! -d "$path" ]] && return 0
  repo=$(git -C "$path" rev-parse --show-toplevel 2>/dev/null || true)
  if [[ -n "$repo" ]]; then
    basename "$repo"
  else
    # Resolve symlinks so /tmp/foo and /private/tmp/foo give the same basename on macOS.
    basename "$(cd "$path" 2>/dev/null && pwd -P)"
  fi
}

detect_ai_tool() {
  local cmd="$1"
  [[ -z "$cmd" ]] && return 0
  if [[ "$cmd" =~ $AI_TOOLS_RE ]]; then
    printf '%s\n' "${BASH_REMATCH[1]}"
  elif [[ "$cmd" =~ $VERSION_CMD_RE ]]; then
    printf 'claude\n'
  fi
}

detect_fg_cmd() {
  local cmd="$1"
  [[ -z "$cmd" ]] && return 0
  [[ "$cmd" =~ $FG_CMDS_RE ]] && printf '%s\n' "${BASH_REMATCH[1]}"
}

format_name() {
  local tool="$1" repo="$2" slug="$3" fg_cmd="$4"
  if [[ -n "$tool" && -n "$repo" ]]; then
    if [[ -n "$slug" ]]; then
      printf '%s:%s:%s\n' "${tool:0:$TOOL_MAX}" "${repo:0:$REPO_MAX}" "${slug:0:$SLUG_MAX}"
    else
      printf '%s:%s\n' "${tool:0:$TOOL_MAX}" "${repo:0:$REPO_MAX}"
    fi
  elif [[ -n "$repo" ]]; then
    if [[ -n "$fg_cmd" ]]; then
      printf '%s:%s\n' "${repo:0:$REPO_MAX}" "${fg_cmd:0:$SLUG_MAX}"
    else
      printf '%s\n' "${repo:0:$MAXLEN}"
    fi
  fi
}

# A window name is "ours / safe to overwrite" if it looks default-ish,
# matches the current cmd (tmux's auto-rename), or starts with a known AI-tool prefix.
# Manual renames the user typed are left alone.
is_managed_name() {
  local name="$1" cmd="$2"
  [[ "$RENAME_ALL" == "1" ]] && return 0
  [[ -z "$name" ]] && return 0
  [[ "$name" =~ $DEFAULT_NAME_RE ]] && return 0
  [[ -n "$cmd" && "$name" == "$cmd" ]] && return 0
  local label
  for label in "${AI_TOOL_LABELS[@]}"; do
    [[ "$name" == "$label":* ]] && return 0
  done
  return 1
}

# --- cache ---

cache_get() {
  local pane_id="$1" tool="$2" repo="$3"
  [[ -f "$CACHE_FILE" ]] || return 1
  local match
  match=$(awk -F'\t' -v p="$pane_id" -v t="$tool" -v r="$repo" \
    '$1==p && $2==t && $3==r {print $4; found=1; exit} END {exit !found}' "$CACHE_FILE") || return 1
  printf '%s\n' "$match"
}

cache_set() {
  local pane_id="$1" tool="$2" repo="$3" slug="$4"
  mkdir -p "$CACHE_DIR"
  if [[ -f "$CACHE_FILE" ]]; then
    local tmp="$CACHE_FILE.tmp.$$"
    awk -F'\t' -v p="$pane_id" -v t="$tool" -v r="$repo" \
      '!($1==p && $2==t && $3==r)' "$CACHE_FILE" > "$tmp"
    mv "$tmp" "$CACHE_FILE"
  fi
  printf '%s\t%s\t%s\t%s\n' "$pane_id" "$tool" "$repo" "$slug" >> "$CACHE_FILE"
}

# Drop rows whose pane_id isn't in the newline-separated live list passed in.
cache_gc_with_live() {
  local live="$1"
  [[ -f "$CACHE_FILE" ]] || return 0
  [[ -z "$live" ]] && return 0
  local tmp="$CACHE_FILE.tmp.$$"
  awk -F'\t' '
    NR==FNR { if ($0 != "") ok[$0] = 1; next }
    ok[$1]
  ' <(printf '%s' "$live") "$CACHE_FILE" > "$tmp"
  mv "$tmp" "$CACHE_FILE"
}

cache_gc() {
  local live
  live=$(tmux list-panes -a -F '#{pane_id}' 2>/dev/null | sort -u) || return 0
  cache_gc_with_live "$live"
}

# --- LLM (only for AI slug) ---

ask_model() {
  local prompt="$1" payload
  payload=$(jq -n --arg model "$MODEL" --arg prompt "$prompt" '{
    model: $model,
    prompt: $prompt,
    stream: false,
    options: { temperature: 0.2, num_predict: 24 }
  }')
  curl -sS --max-time 20 "$HOST/api/generate" \
    -H 'Content-Type: application/json' \
    -d "$payload" \
    | jq -r '.response // empty'
}

prompt_ai_task() {
  local tool="$1" repo="$2" title="$3" content="$4"
  cat <<EOF
You are naming a tmux window where an AI coding agent ($tool) is working. The repo is "$repo". The terminal title (if set by the agent) is: "$title". The recent pane content is below.

Reply with a SHORT 1-3 word lowercase phrase describing the current TASK the agent is working on (not the tool, not the repo). Examples: "dashboard", "auth fix", "tmux renamer", "ci debug". No punctuation, no quotes, no explanation. Just the task.

Content:
$content
EOF
}

# Returns a slug, possibly empty. Uses cache unless force=1.
slug_for_ai_pane() {
  local pane_id="$1" tool="$2" repo="$3" title="$4" target="$5" force="${6:-0}"
  if [[ "$force" != "1" ]]; then
    local cached
    cached=$(cache_get "$pane_id" "$tool" "$repo" 2>/dev/null || true)
    if [[ -n "$cached" ]]; then
      printf '%s\n' "$cached"
      return 0
    fi
  fi
  local content raw slug
  content=$(tmux capture-pane -t "$target" -p -S -"$LINES" 2>/dev/null \
    | sed '/^[[:space:]]*$/d' | tail -n "$LINES")
  [[ -z "$content" ]] && return 0
  raw=$(ask_model "$(prompt_ai_task "$tool" "$repo" "$title" "$content")" || true)
  slug=$(printf '%s' "$raw" | sanitize_label "$SLUG_MAX")
  [[ -n "$slug" ]] && cache_set "$pane_id" "$tool" "$repo" "$slug"
  printf '%s\n' "$slug"
}

# --- main per-window logic ---

process_window() {
  local target="$1" current="$2" cmd="$3" path="$4" title="$5" pane_id="$6" force="${7:-0}"

  is_managed_name "$current" "$cmd" || return 0

  local tool repo fg_cmd slug new
  tool=$(detect_ai_tool "$cmd")
  repo=$(repo_for_path "$path")

  if [[ -n "$tool" ]]; then
    [[ -z "$repo" ]] && repo="$tool"
    slug=$(slug_for_ai_pane "$pane_id" "$tool" "$repo" "$title" "$target" "$force")
    new=$(format_name "$tool" "$repo" "$slug" '')
  else
    # Non-AI: deterministic only. No repo => leave alone.
    [[ -z "$repo" ]] && return 0
    fg_cmd=$(detect_fg_cmd "$cmd")
    new=$(format_name '' "$repo" '' "$fg_cmd")
  fi

  [[ -z "$new" ]] && return 0
  new="${new:0:$MAXLEN}"
  [[ "$new" == "$current" ]] && return 0
  tmux rename-window -t "$target" "$new" && log "$target: '$current' -> '$new'"
}

sweep() {
  local fmt
  fmt=$'#{session_name}:#{window_index}\t#{window_name}\t#{pane_current_command}\t#{pane_current_path}\t#{pane_title}\t#{pane_id}'
  while IFS=$'\t' read -r target name cmd path title pane_id; do
    [[ -z "$target" ]] && continue
    process_window "$target" "$name" "$cmd" "$path" "$title" "$pane_id" 0 || true
  done < <(tmux list-windows -a -F "$fmt")
  cache_gc || true
}

rename_once() {
  local target="$1" force="${2:-1}"
  local fmt info
  fmt=$'#{window_name}\t#{pane_current_command}\t#{pane_current_path}\t#{pane_title}\t#{pane_id}'
  info=$(tmux display-message -p -t "$target" "$fmt" 2>/dev/null) || return 1
  IFS=$'\t' read -r name cmd path title pane_id <<<"$info"
  process_window "$target" "$name" "$cmd" "$path" "$title" "$pane_id" "$force"
}

usage() {
  cat <<EOF
tmux-auto-name - rename tmux windows deterministically (LLM only for AI-pane slug, cached)

Usage:
  tmux-auto-name                       Run polling daemon (every \$TAN_INTERVAL=$INTERVAL s)
  tmux-auto-name --once <target>       Rename one window now (bypasses slug cache)
  tmux-auto-name --watch <target>      Sleep \$TAN_WATCH_DELAY=\${TAN_WATCH_DELAY:-120} s, then rename once (uses cache)
  tmux-auto-name --sweep               One full sweep, then exit
EOF
}

main() {
  command -v jq >/dev/null || { echo "tan: jq required" >&2; exit 1; }
  command -v curl >/dev/null || { echo "tan: curl required" >&2; exit 1; }
  command -v tmux >/dev/null || { echo "tan: tmux required" >&2; exit 1; }

  case "${1:-daemon}" in
    --once)
      [[ -z "${2:-}" ]] && { usage; exit 2; }
      rename_once "$2" 1
      ;;
    --watch)
      [[ -z "${2:-}" ]] && { usage; exit 2; }
      sleep "${TAN_WATCH_DELAY:-120}"
      rename_once "$2" 0
      ;;
    --sweep)
      sweep
      ;;
    -h|--help)
      usage
      ;;
    daemon)
      log "starting model=$MODEL interval=${INTERVAL}s rename_all=$RENAME_ALL"
      while true; do
        sweep || log "sweep error (continuing)"
        sleep "$INTERVAL"
      done
      ;;
    *)
      usage; exit 2
      ;;
  esac
}

# Only dispatch when executed directly; sourcing (tests) loads functions only.
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  main "$@"
fi
