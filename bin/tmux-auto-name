#!/usr/bin/env bash
# tmux-auto-name: rename tmux windows using a local LLM (Ollama).
# AI-coder-aware: for windows running claude/codex/opencode/gemini/goose/aider/droid,
# names them as "<repo>: <task>".
set -euo pipefail

MODEL="${TAN_MODEL:-qwen2.5:1.5b}"
INTERVAL="${TAN_INTERVAL:-30}"
LINES="${TAN_LINES:-80}"
HOST="${TAN_OLLAMA_HOST:-http://localhost:11434}"
RENAME_ALL="${TAN_RENAME_ALL:-0}"
MAXLEN="${TAN_MAXLEN:-32}"

# Window names matching this regex are treated as "default" and eligible for renaming.
# Anything else is assumed manually named and left alone (unless TAN_RENAME_ALL=1).
DEFAULT_NAME_RE='^(zsh|bash|sh|fish|[0-9]+|)$'

# Commands considered AI coding agents (substring match, since processes can appear
# as e.g. "codex-aarch64-a" or as a version string like "2.1.143" for Claude Code).
AI_TOOLS_RE='(claude|codex|opencode|gemini|goose|aider|droid|crush|cursor|cody)'
# Version-number-only command names (e.g. Claude Code shows up as "2.1.143")
VERSION_CMD_RE='^[0-9]+\.[0-9]+(\.[0-9]+)?$'

log() { printf '[tan %s] %s\n' "$(date +%H:%M:%S)" "$*" >&2; }

# Cleanup a free-form label to: lowercase, alphanum + hyphens, capped length.
sanitize_label() {
  local maxlen="${1:-24}"
  tr '[:upper:]' '[:lower:]' \
    | tr -d '"`'"'" \
    | tr -c 'a-z0-9 \n' ' ' \
    | awk '{
        n = (NF < 3) ? NF : 3
        if (n == 0) { print ""; next }
        out = $1
        for (i = 2; i <= n; i++) out = out "-" $i
        print out
      }' \
    | cut -c1-"$maxlen"
}

# Repo name from a path. Uses git toplevel if inside a repo, else the basename.
repo_for_path() {
  local path="$1" repo
  [[ -z "$path" || ! -d "$path" ]] && return 0
  repo=$(git -C "$path" rev-parse --show-toplevel 2>/dev/null || true)
  if [[ -n "$repo" ]]; then
    basename "$repo"
  else
    basename "$path"
  fi
}

ask_model() {
  local prompt="$1" payload
  payload=$(jq -n --arg model "$MODEL" --arg prompt "$prompt" '{
    model: $model,
    prompt: $prompt,
    stream: false,
    options: { temperature: 0.2, num_predict: 24 }
  }')
  curl -sS --max-time 20 "$HOST/api/generate" \
    -H 'Content-Type: application/json' \
    -d "$payload" \
    | jq -r '.response // empty'
}

prompt_generic() {
  local content="$1"
  cat <<EOF
You name tmux windows. Given the recent terminal output below, reply with a 1-3 word lowercase label describing what is happening (the program, project, or task). No punctuation, no quotes, no explanation. Just the label.

Output:
$content
EOF
}

prompt_ai_task() {
  local tool="$1" repo="$2" title="$3" content="$4"
  cat <<EOF
You are naming a tmux window where an AI coding agent ($tool) is working. The repo is "$repo". The terminal title (if set by the agent) is: "$title". The recent pane content is below.

Reply with a SHORT 1-3 word lowercase phrase describing the current TASK the agent is working on (not the tool, not the repo). Examples: "dashboard", "auth fix", "tmux renamer", "ci debug". No punctuation, no quotes, no explanation. Just the task.

Content:
$content
EOF
}

process_window() {
  local target="$1" current="$2" cmd="$3" path="$4" title="$5"

  if [[ "$RENAME_ALL" != "1" && ! "$current" =~ $DEFAULT_NAME_RE ]]; then
    # User manually named this window or an AI-coder name we already set.
    # Heuristic: an existing AI-coder name contains a colon ("repo: task") -
    # we DO want to keep refreshing those, so allow if it contains ":".
    [[ "$current" == *:* ]] || return 0
  fi

  local content
  content=$(tmux capture-pane -t "$target" -p -S -"$LINES" 2>/dev/null | sed '/^[[:space:]]*$/d' | tail -n "$LINES")
  [[ -z "$content" ]] && return 0

  local is_ai=0 tool_label="$cmd"
  if [[ "$cmd" =~ $AI_TOOLS_RE ]]; then
    is_ai=1
    tool_label="${BASH_REMATCH[1]}"
  elif [[ "$cmd" =~ $VERSION_CMD_RE ]]; then
    # Bare version-number command is almost always Claude Code.
    is_ai=1
    tool_label="claude"
  fi

  local new
  if [[ "$is_ai" == "1" ]]; then
    local repo task raw
    repo=$(repo_for_path "$path")
    [[ -z "$repo" ]] && repo="$tool_label"
    raw=$(ask_model "$(prompt_ai_task "$tool_label" "$repo" "$title" "$content")" || true)
    task=$(printf '%s' "$raw" | sanitize_label 18)
    if [[ -n "$task" ]]; then
      new="${repo}: ${task}"
    else
      new="$repo"
    fi
  else
    local raw
    raw=$(ask_model "$(prompt_generic "$content")" || true)
    new=$(printf '%s' "$raw" | sanitize_label 24)
  fi

  [[ -z "$new" ]] && return 0
  # Hard cap on final length
  new="${new:0:$MAXLEN}"
  [[ "$new" == "$current" ]] && return 0

  tmux rename-window -t "$target" "$new" && log "$target: '$current' -> '$new'"
}

sweep() {
  local fmt
  fmt=$'#{session_name}:#{window_index}\t#{window_name}\t#{pane_current_command}\t#{pane_current_path}\t#{pane_title}'
  while IFS=$'\t' read -r target name cmd path title; do
    [[ -z "$target" ]] && continue
    process_window "$target" "$name" "$cmd" "$path" "$title" || true
  done < <(tmux list-windows -a -F "$fmt")
}

# Run process_window for a single target, looking up its attributes from tmux.
rename_once() {
  local target="$1"
  local fmt info
  fmt=$'#{window_name}\t#{pane_current_command}\t#{pane_current_path}\t#{pane_title}'
  info=$(tmux display-message -p -t "$target" "$fmt" 2>/dev/null) || return 1
  IFS=$'\t' read -r name cmd path title <<<"$info"
  process_window "$target" "$name" "$cmd" "$path" "$title"
}

command -v jq >/dev/null || { echo "tan: jq required" >&2; exit 1; }
command -v curl >/dev/null || { echo "tan: curl required" >&2; exit 1; }
command -v tmux >/dev/null || { echo "tan: tmux required" >&2; exit 1; }

usage() {
  cat <<EOF
tmux-auto-name - rename tmux windows via local LLM

Usage:
  tmux-auto-name                       Run polling daemon (every \$TAN_INTERVAL=$INTERVAL s)
  tmux-auto-name --once <target>       Rename one window now
  tmux-auto-name --watch <target>      Sleep \$TAN_WATCH_DELAY=\${TAN_WATCH_DELAY:-120} s, then rename once
  tmux-auto-name --sweep               One full sweep, then exit
EOF
}

case "${1:-daemon}" in
  --once)
    [[ -z "${2:-}" ]] && { usage; exit 2; }
    rename_once "$2"
    ;;
  --watch)
    [[ -z "${2:-}" ]] && { usage; exit 2; }
    sleep "${TAN_WATCH_DELAY:-120}"
    rename_once "$2"
    ;;
  --sweep)
    sweep
    ;;
  -h|--help)
    usage
    ;;
  daemon)
    log "starting model=$MODEL interval=${INTERVAL}s rename_all=$RENAME_ALL"
    while true; do
      sweep || log "sweep error (continuing)"
      sleep "$INTERVAL"
    done
    ;;
  *)
    usage; exit 2
    ;;
esac
